# ─────────────────────────────────────────────────────────────────────────────
# Knowledge Base — Environment Configuration
# Copy this file to .env and fill in the required values.
# ─────────────────────────────────────────────────────────────────────────────


# ── Required ──────────────────────────────────────────────────────────────────

DB_PASSWORD=changeme          # Strong password for the Postgres database
OPENAI_API_KEY=               # sk-... from platform.openai.com


# ── Host Bindings ─────────────────────────────────────────────────────────────
# Controls what IP and ports are exposed on the host machine.
# BIND_HOST should be your server's LAN IP (or 0.0.0.0 to bind all interfaces).

BIND_HOST=192.168.178.40
API_PORT=8000                 # REST API
POSTGRES_PORT=5435            # Postgres (offset from default 5432 to avoid conflicts)
MCP_PORT=3000                 # MCP server (SSE)


# ── Host Paths ────────────────────────────────────────────────────────────────
# Bind mount location for Postgres data on the host.
# Use the cache drive on Unraid — never /mnt/user (Mover will relocate it).

POSTGRES_DATA_PATH=/mnt/cache/appdata/knowledge-base-postgres


# ── Internal — Do Not Change ──────────────────────────────────────────────────
# These are used inside Docker Compose and reference internal service names
# and container-side ports. They do not need to match the host bindings above.

DB_HOST=postgres              # Docker Compose service name
DB_PORT=5432                  # Postgres port inside the container (always 5432)
DB_NAME=knowledge
DB_USER=postgres
API_BASE_URL=http://api:8000  # MCP → API communication (internal network)


# ── Embedding Model ───────────────────────────────────────────────────────────
# Change only if you want to use a different OpenAI embedding model.
# If you change the model, you must also update EMBEDDING_DIMS to match
# and re-embed all existing chunks.

EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMS=3072
